# OmniMind Backend Environment Configuration

# Hugging Face API Key (for image generation)
# Get from: https://huggingface.co/settings/tokens
HUGGING_FACE_API_KEY=your_huggingface_api_key_here

# Astra DB Configuration (for chat history storage)
# Get from: https://astra.datastax.com/
ASTRA_DB_APPLICATION_TOKEN=AstraCS:your_actual_token_here
ASTRA_DB_API_ENDPOINT=https://your-db-id-your-region.apps.astra.datastax.com

# Groq API Key (for AI chat)
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
